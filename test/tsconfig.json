{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "exactOptionalPropertyTypes": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": false,
    "strict": true,
    "target": "ES2022",
    "types": []
  },
  "include": [
    "./types.ts"
  ]
}

